# Generate a secret key:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=America/Los_Angeles

# Production
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
# Optional HSTS (defaults: 1 year HSTS, subdomains/preload off)
# DJANGO_HSTS_SECONDS=31536000
# DJANGO_HSTS_INCLUDE_SUBDOMAINS=false
# DJANGO_HSTS_PRELOAD=false
