{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/address-book-portal/schema/tag.schema.json",
  "title": "Tag",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "readOnly": true
    },
    "owner_id": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "default": "#2563eb"
    },
    "contact_ids": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "default": []
    }
  },
  "required": ["owner_id", "name"]
}
