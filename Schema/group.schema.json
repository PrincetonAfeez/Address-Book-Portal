{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/address-book-portal/schema/group.schema.json",
  "title": "Group",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "readOnly": true
    },
    "owner_id": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "contact_ids": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "default": []
    }
  },
  "required": ["owner_id", "name"]
}
