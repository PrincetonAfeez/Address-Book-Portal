{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/address-book-portal/schema/phone.schema.json",
  "title": "Phone",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "readOnly": true
    },
    "contact_id": {
      "type": "integer",
      "minimum": 1
    },
    "number": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "label": {
      "type": "string",
      "enum": ["mobile", "work", "home"],
      "default": "mobile"
    }
  },
  "required": ["contact_id", "number"]
}
